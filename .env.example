# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/rv_crm

# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase (optional — external inventory source)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# SUPABASE_DB_URL=postgresql://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# Anthropic (optional — AI sales assistant + matching)
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# SendGrid (optional — email notifications)
# SENDGRID_API_KEY=SG.your-key-here
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Twilio (optional — SMS notifications)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Web Scraping (optional)
# TINYFISH_API_KEY=sk-tinyfish-your-key-here

# Frontend URL (optional — for CORS)
# FRONTEND_URL=https://your-app.com

# Seed passwords (only needed for initial database setup)
# SEED_OWNER_PASSWORD=your_secure_owner_password
# SEED_ADMIN_PASSWORD=your_secure_admin_password
# SEED_DEMO_PASSWORD=your_secure_demo_password
