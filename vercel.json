{
  "buildCommand": "npx expo export --platform web --output-dir dist && cp public/opt-in.html dist/opt-in.html",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
